def main():
    for i in r(0, 1000]:
        result = ""
        if fizzy(i):
            result = result + "Fizz"
        if buzzy(i):
            result = result + "Buzz"
        if len(result) > 0:
            print result
        else:
            print str(i)

def fizzy(x):
    return x % 3 == 0

def buzzy(x):
    return x % 5 == 0